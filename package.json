{
  "name": "roca-de-vida",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev:web": "turbo run dev --filter=web",
    "dev:cms": "turbo run dev --filter=cms"
  },
  "devDependencies": {
    "turbo": "^2.5.3",
    "typescript": "^5.8.3",
    "@types/node": "^22.15.17"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.17.1",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "unrs-resolver"]
  }
}
